# Firebase Configuration Example
# Replace these with your actual Firebase credentials
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# User Passwords
# Change these to your secure passwords for production
VITE_USER_ADMIN_PASSWORD=admin123
VITE_USER_USER1_PASSWORD=user1pass
VITE_USER_USER2_PASSWORD=user2pass
VITE_USER_USER3_PASSWORD=user3pass
VITE_USER_USER4_PASSWORD=user4pass
