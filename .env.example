# Firebase Configuration
# Copiez ce fichier vers .env et remplacez les valeurs par les vôtres
# Obtenez ces valeurs depuis la console Firebase : https://console.firebase.google.com

# Configuration complète (format JSON) — prioritaire sur les variables individuelles
VITE_FIREBASE_CONFIG={"apiKey":"AIzaSy...","authDomain":"votre-projet.firebaseapp.com","projectId":"votre-projet","storageBucket":"votre-projet.appspot.com","messagingSenderId":"123456789","appId":"1:123:web:abc"}

# Variables individuelles (utilisées si VITE_FIREBASE_CONFIG n'est pas défini)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre-projet
VITE_FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc

